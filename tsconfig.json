{
  "compilerOptions": {
    "esModuleInterop":    true,
    "isolatedModules":    true,
    "jsx":                "react-jsx",
    "jsxImportSource":    "preact",
    "lib":                ["DOM", "ES2020"],
    "module":             "ES2020",
    "moduleResolution":   "Node",
    "strict":             true,
    "skipLibCheck":       true
  },
  "include": ["src/**/*"]
}
